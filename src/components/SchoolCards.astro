---
import { Image } from "astro:assets";
import smpImage from "../assets/smp.webp";
import smaImage from "../assets/sma.webp";
import smkImage from "../assets/smk.webp";
import cbt from "../assets/cbt-online.webp";

const schoolProducts = [
  {
    name: "Paket Website SMP",
    level: "SMP",
    image: smpImage,
    link: "https://template-smp-new.pages.dev/",
  },
  {
    name: "Paket Website SMA",
    level: "SMA",
    image: smaImage,
    link: "https://template-sma.pages.dev/",
    popular: true,
  },
  {
    name: "Paket Website SMK",
    level: "SMK",
    image: smkImage,
    link: "https://template-smk.pages.dev/",
  },
  {
    name: "Aplikasi SAS CBT",
    level: "CBT",
    image: cbt, // Placeholder
    link: "#",
    comingSoon: true,
  },
];
---

<section id="demo" class="pb-32 pt-12 bg-slate-50 relative overflow-hidden">
  <!-- Modern Background Decorations -->
  <div
    class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none"
  >
    <div
      class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]"
    >
    </div>
    <div
      class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-indigo-50/50 blur-[120px]"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2
        class="text-4xl md:text-5xl font-extrabold mb-8 text-slate-900 tracking-tight"
      >
        Eksplorasi
        <span class="text-blue-600 italic"> Produk Kami </span>
      </h2>
      <div
        class="w-20 h-1.5 bg-linear-to-r from-blue-600 to-indigo-600 mx-auto rounded-full mb-8"
      >
      </div>
      <p
        class="text-slate-500 text-lg leading-relaxed max-w-2xl mx-auto font-medium"
      >
        Lihat langsung bagaimana sistem kami mentransformasi kehadiran digital
        institusi pendidikan Anda.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto"
    >
      {
        schoolProducts.map((item) => (
          <div class="group h-full">
            <div
              class={`relative h-full bg-white rounded-md overflow-hidden transition-all duration-500 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_50px_rgba(79,70,229,0.15)] hover:-translate-y-2 flex flex-col ${item.popular ? "ring-2 ring-indigo-500/20 shadow-[0_20px_50px_rgba(79,70,229,0.1)]" : ""}`}
            >
              {/* Image Container - Aspect Video */}
              <div class="relative aspect-video overflow-hidden bg-slate-100">
                <Image
                  src={item.image}
                  alt={item.name}
                  class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                />

                {item.popular && (
                  <div class="absolute top-3 right-3">
                    <span class="px-2 py-1 bg-indigo-600 rounded text-[10px] font-black text-white uppercase tracking-wider shadow-lg">
                      POPULER
                    </span>
                  </div>
                )}
              </div>

              {/* Content Section - Below Image */}
              <div class="p-6 flex flex-col grow">
                <div class="flex items-center justify-between mb-4">
                  <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-widest rounded border border-slate-200">
                    {item.level}
                  </span>
                </div>

                <h3 class="text-lg font-bold text-slate-900 mb-6 leading-tight">
                  {item.name}
                </h3>

                <div class="mt-auto">
                  {item.comingSoon ? (
                    <button class="w-full py-3.5 px-6 bg-slate-100 text-slate-400 font-bold rounded-md cursor-not-allowed border border-slate-200 text-xs tracking-widest uppercase">
                      Segera Hadir
                    </button>
                  ) : (
                    <a href={item.link} target="_blank" class="block w-full">
                      <button class="w-full py-3.5 px-6 bg-indigo-600 text-white font-bold rounded-md shadow-[0_4px_12px_-2px_rgba(79,70,229,0.3)] hover:bg-indigo-700 hover:shadow-[0_8px_16px_-2px_rgba(79,70,229,0.4)] transition-all duration-300 text-xs tracking-widest uppercase flex items-center justify-center gap-2 group/btn">
                        Live Demo
                        <svg
                          class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                          />
                        </svg>
                      </button>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
